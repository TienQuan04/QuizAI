<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:cardview="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/main_background">

    <!-- Tiêu đề -->
    <LinearLayout
        android:id="@+id/headerLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#2196F3"
        android:orientation="vertical"
        android:padding="16dp"
        android:layout_alignParentTop="true">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="QUIZZAI"
            android:textSize="30sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:gravity="center" />
    </LinearLayout>

    <!-- Nội dung -->
    <LinearLayout
        android:id="@+id/contentLayout"
        android:layout_below="@id/headerLayout"
        android:layout_above="@id/historyBtn"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:layout_marginTop="16dp">

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:elevation="2dp"
            android:layout_marginBottom="24dp"
            cardview:cardCornerRadius="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Chủ đề -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Chủ đề Quiz"
                    android:textColor="#2196F3"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <EditText
                    android:id="@+id/subjectInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Nhập chủ đề (VD: Lịch sử)"
                    android:background="@drawable/rounded_edit_text"
                    android:padding="12dp"
                    android:layout_marginBottom="16dp" />

                <!-- Số câu -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Số câu hỏi"
                    android:textColor="#2196F3"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/questionCountText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="10 câu hỏi"
                    android:background="@drawable/rounded_edit_text"
                    android:padding="12dp"
                    android:gravity="center"
                    android:textSize="16sp"
                    android:layout_marginBottom="8dp" />

                <SeekBar
                    android:id="@+id/questionCountSeekBar"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp" />

                <!-- Thời gian -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Thời gian mỗi câu (giây)"
                    android:textColor="#2196F3"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/timerInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="30 giây"
                    android:background="@drawable/rounded_edit_text"
                    android:padding="12dp"
                    android:gravity="center"
                    android:textSize="16sp"
                    android:layout_marginBottom="8dp" />

                <SeekBar
                    android:id="@+id/timerSeekBar"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

    </LinearLayout>

    <!-- Nút xem lịch sử -->
    <Button
        android:id="@+id/historyBtn"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="XEM LỊCH SỬ"
        android:textStyle="bold"
        android:textSize="16sp"
        android:textColor="@android:color/white"
        android:backgroundTint="#4CAF50"
        android:layout_above="@id/profileBtn"
        android:layout_marginStart="40dp"
        android:layout_marginEnd="40dp"
        android:layout_marginBottom="10dp"/>

    <!-- Nút xem profile -->
    <Button
        android:id="@+id/profileBtn"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="XEM PROFILE"
        android:textStyle="bold"
        android:textSize="16sp"
        android:textColor="@android:color/white"
        android:backgroundTint="#FF9800"
        android:layout_above="@id/generateBtn"
        android:layout_marginStart="40dp"
        android:layout_marginEnd="40dp"
        android:layout_marginBottom="10dp"/>

    <!-- Nút tạo quiz -->
    <Button
        android:id="@+id/generateBtn"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="TẠO QUIZ VỚI AI"
        android:textStyle="bold"
        android:textAllCaps="true"
        android:textSize="18sp"
        android:padding="16dp"
        android:textColor="@android:color/white"
        android:layout_alignParentBottom="true"
        android:backgroundTint="@drawable/button_blue_selector"
        android:layout_margin="40dp" />

</RelativeLayout>
